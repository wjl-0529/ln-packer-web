# 服务器 Docker Compose 部署配置示例
# 复制为 .env 后按需修改，然后运行：docker compose up -d --build

PACKER_PORT=8080
PACKER_ACCESS_TOKEN=
PACKER_MAX_CONCURRENT=1
PACKER_CHAPTER_CONCURRENCY=6
PACKER_IMAGE_CONCURRENCY=8
PACKER_SOURCE_RATE_MODE=stable
PACKER_FILE_TTL_HOURS=24

# 如国内服务器拉取官方镜像较慢，可替换成镜像站中的等价镜像。
NODE_IMAGE=node:22-alpine
DART_IMAGE=dart:stable
DEBIAN_IMAGE=debian:bookworm-slim
APT_MIRROR=
